# Private key for deployments (DO NOT COMMIT YOUR REAL PRIVATE KEY)
PRIVATE_KEY=your_private_key_here

# Coinbase Developer Platform (CDP) API Keys
# Get these from: https://portal.cdp.coinbase.com/
CDP_API_KEY_NAME=your_cdp_api_key_name
CDP_PRIVATE_KEY=your_cdp_private_key

# OnchainKit API Key (for frontend)
# Get from: https://portal.cdp.coinbase.com/
NEXT_PUBLIC_ONCHAINKIT_API_KEY=your_onchainkit_api_key

# Coinbase Wallet App Configuration
COINBASE_WALLET_APP_NAME=Nabat Omnichain dApp
COINBASE_WALLET_APP_LOGO_URL=https://your-domain.com/logo.png

# RPC URLs
ETHEREUM_RPC=https://eth-mainnet.g.alchemy.com/v2/your-api-key
BASE_RPC=https://mainnet.base.org
BASE_SEPOLIA_RPC=https://sepolia.base.org
POLYGON_RPC=https://polygon-rpc.com
ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC=https://mainnet.optimism.io
AVALANCHE_RPC=https://api.avax.network/ext/bc/C/rpc
BSC_RPC=https://bsc-dataseed1.binance.org

# Block Explorer API Keys
ETHERSCAN_API_KEY=your_etherscan_api_key
BASESCAN_API_KEY=your_basescan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key
ARBISCAN_API_KEY=your_arbiscan_api_key
OPTIMISM_API_KEY=your_optimism_api_key
SNOWTRACE_API_KEY=your_snowtrace_api_key
BSCSCAN_API_KEY=your_bscscan_api_key
