# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# 
# IMPORTANT: This configuration supports both TESTNETS (Sepolia) and mainnet
# For development/testing: Get free testnet ETH from faucets (see FAUCETS.md)

# Application Configuration
NODE_ENV=development
PORT=3000

# Network Configuration (TESTNET recommended for development)
# Ethereum Sepolia Chain ID: 11155111
# Base Sepolia Chain ID: 84532
NETWORK=testnet

# Private Keys (NEVER commit these - keep .env in .gitignore)
PRIVATE_KEY=
# Testnet Private Key (WARNING: Never commit actual private keys!)
# This should be a wallet with TESTNET ETH only
BASE_TESTNET_PRIVATE_KEY=

# LayerZero Configuration
# Universal LayerZero V2 Endpoint Address (same for all chains)
LAYERZERO_ENDPOINT=0x1a44076050125825900e736c501f859c50fE728c

# Deployment Configuration
DELEGATE_ADDRESS=your_deployer_address_here

# Coinbase Developer Platform (CDP) API Keys
# Get these from: https://portal.cdp.coinbase.com/
CDP_API_KEY_NAME=your_cdp_api_key_name
CDP_PRIVATE_KEY=your_cdp_private_key

# OnchainKit API Key (for frontend)
# Get from: https://portal.cdp.coinbase.com/
NEXT_PUBLIC_ONCHAINKIT_API_KEY=your_onchainkit_api_key

# Coinbase Wallet App Configuration
COINBASE_WALLET_APP_NAME=Nabat Omnichain dApp
COINBASE_WALLET_APP_LOGO_URL=https://your-domain.com/logo.png

# Alchemy API Key
ALCHEMY_API_KEY=

# Testnet RPC URLs (RECOMMENDED for development)
# Ethereum Sepolia Configuration (TESTNET)
ETH_SEPOLIA_RPC=
ETH_SEPOLIA_CHAIN_ID=11155111

# Base Sepolia Configuration (TESTNET)
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_SEPOLIA_CHAIN_ID=84532

# Mainnet RPC URLs (configure for production deployment)
ETHEREUM_RPC=https://eth-mainnet.g.alchemy.com/v2/your-api-key
ETHEREUM_RPC_URL=
BASE_RPC=https://mainnet.base.org
BASE_RPC_URL=
POLYGON_RPC=https://polygon-rpc.com
POLYGON_RPC_URL=
ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
ARBITRUM_RPC_URL=
OPTIMISM_RPC=https://mainnet.optimism.io
OPTIMISM_RPC_URL=
BSC_RPC=https://bsc-dataseed1.binance.org
BSC_RPC_URL=
AVALANCHE_RPC=https://api.avax.network/ext/bc/C/rpc
AVALANCHE_RPC_URL=

# Block Explorer API Keys (for contract verification)
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=
POLYGONSCAN_API_KEY=
ARBISCAN_API_KEY=
OPTIMISTIC_ETHERSCAN_API_KEY=
OPTIMISM_API_KEY=
BSCSCAN_API_KEY=
SNOWTRACE_API_KEY=

# Database (if applicable)
DATABASE_URL=
