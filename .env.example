# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# 
# IMPORTANT: This configuration uses TESTNETS (Sepolia), NOT mainnet
# Get free testnet ETH from faucets (see README.md)

# Application Configuration
NODE_ENV=development
PORT=3000

# Network Configuration (TESTNET - Do not use mainnet!)
# Ethereum Sepolia Chain ID: 11155111
# Base Sepolia Chain ID: 84532
NETWORK=testnet

# Alchemy API Key
ALCHEMY_API_KEY=

# Ethereum Sepolia Configuration (TESTNET)
ETH_SEPOLIA_RPC=
ETH_SEPOLIA_CHAIN_ID=11155111

# Base Sepolia Configuration (TESTNET)
BASE_SEPOLIA_RPC=
BASE_SEPOLIA_CHAIN_ID=84532

# Testnet Private Key (WARNING: Never commit actual private keys!)
# This should be a wallet with TESTNET ETH only
BASE_TESTNET_PRIVATE_KEY=

# Database (if applicable)
DATABASE_URL=
