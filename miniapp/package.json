{
  "name": "onbt-miniapp",
  "version": "1.0.0",
  "description": "ONBT DeFi Miniapp - Staking, Swapping, and Liquidity on Base",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "minikit:manifest": "create-onchain --manifest",
    "minikit:scaffold": "create-onchain --mini",
    "type-check": "tsc --noEmit",
    "rate:app": "node scripts/rate-app.mjs",
    "rate:app:quick": "node scripts/rate-app.mjs --quick",
    "rate:app:ci": "node scripts/rate-app.mjs --ci",
    "advance:miniapp": "node scripts/advance-miniapp.mjs",
    "advance:miniapp:quick": "node scripts/advance-miniapp.mjs --quick",
    "advance:miniapp:fix": "node scripts/advance-miniapp.mjs --fix",
    "advance:miniapp:ci": "node scripts/advance-miniapp.mjs --ci --strict"
  },
  "dependencies": {
    "@coinbase/onchainkit": "^0.38.0",
    "@coinbase/wallet-sdk": "^4.3.7",
    "@farcaster/frame-sdk": "^0.1.8",
    "@farcaster/miniapp-sdk": "^0.2.3",
    "@tanstack/react-query": "^5.0.0",
    "next": "^15.5.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.0.0",
    "wagmi": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.12",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.11.0",
    "npm": ">=9.0.0"
  }
}
